# LLM API配置（支持 OpenAI SDK 格式的任意 LLM API）
# 推荐使用阿里百炼平台qwen-plus模型：https://bailian.console.aliyun.com/
# 注意消耗较大，可先进行小于40轮的模拟尝试
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== ZEP记忆图谱配置 =====
# 每月免费额度即可支撑简单使用：https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== 加速 LLM 配置（可选）=====
# 注意如果不使用加速配置，env文件中就不要出现下面的配置项
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here

# ===== 足球预测系统配置 =====

# Football-Data.org API (主要数据源, 免费 10 req/min)
# 注册: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=your_football_data_api_key_here

# API-Football (备用数据源, 免费 100 req/day)
# 注册: https://www.api-football.com/
API_FOOTBALL_KEY=your_api_football_key_here

# OpenWeatherMap API (天气数据)
# 注册: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# PostgreSQL 数据库 (足球结构化数据)
FOOTBALL_DB_HOST=localhost
FOOTBALL_DB_PORT=5432
FOOTBALL_DB_NAME=mirofish_football
FOOTBALL_DB_USER=mirofish
FOOTBALL_DB_PASSWORD=your_db_password_here

# 数据更新频率
DATA_UPDATE_INTERVAL_HOURS=6
MATCH_DAY_UPDATE_INTERVAL_MINUTES=30

# ML 模型重训练间隔（天）
ML_RETRAIN_INTERVAL_DAYS=7

# 双层预测融合权重 (ML 40% + Agent 60%)
ML_PREDICTION_WEIGHT=0.4
AGENT_PREDICTION_WEIGHT=0.6